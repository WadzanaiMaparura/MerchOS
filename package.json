{
  "name": "merch-os",
  "version": "0.1.0",
  "private": true,
  "description": "MerchOS — multi-tenant marketplace product management platform",
  "workspaces": [
    "services/*",
    "infrastructure",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "synth": "cd infrastructure && npx cdk synth",
    "deploy:dev": "cd infrastructure && npx cdk deploy --all --context env=dev"
  },
  "devDependencies": {
    "turbo": "2.1.3",
    "typescript": "5.4.5",
    "eslint": "8.57.0",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "prettier": "3.3.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
