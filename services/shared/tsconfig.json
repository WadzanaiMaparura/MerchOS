{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "declarationDir": "dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@merch-os/rbac": ["../../packages/rbac/src/index.ts"]
    }
  },
  "include": [
    "types/**/*.ts",
    "utils/**/*.ts",
    "middleware/**/*.ts",
    "lifecycle/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**"
  ],
  "references": [
    { "path": "../../packages/rbac" }
  ]
}
