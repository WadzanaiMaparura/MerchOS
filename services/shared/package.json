{
  "name": "@merch-os/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types, utilities, and middleware for the MerchOS platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "lint": "eslint 'types/**/*.ts' 'utils/**/*.ts' 'middleware/**/*.ts' 'lifecycle/**/*.ts'",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.654.0",
    "@aws-sdk/lib-dynamodb": "3.654.0",
    "@aws-lambda-powertools/logger": "2.7.0",
    "@aws-lambda-powertools/tracer": "2.7.0",
    "@aws-lambda-powertools/metrics": "2.7.0",
    "@middy/core": "5.4.7"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.140",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  }
}
